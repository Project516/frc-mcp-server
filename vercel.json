{
  "version": 2,
  "builds": [
    {
      "src": "src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/mcp",
      "dest": "/src/index.ts"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    }
  ]
}